---
import { siteConfig } from "@/site.config";

const year = new Date().getFullYear();
// Footer follows the main navigation order, with footer-only context pages
// inserted before the final About link.
const footerLinks = [
	{ path: "/", title: "Home" },
	{ path: "/posts/", title: "Posts" },
	{ path: "/projects/", title: "Projects" },
	{ path: "/notes/", title: "Notes" },
	{ path: "/tags/", title: "Tags" },
	{ path: "/graph/", title: "Graph" },
	{ path: "/now/", title: "Now" },
	{ path: "/uses/", title: "Uses" },
	{ path: "/series/", title: "Series" },
	{ path: "/about/", title: "About" },
];
---

<footer class="text-muted mt-auto pb-4 font-semibold text-sm sm:text-xs">
	<div class="flex w-full flex-col items-center justify-center gap-y-3 text-center sm:flex-row sm:justify-between sm:gap-y-0">
		<div class="me-0 sm:me-4">
			&copy; {siteConfig.author}
			{year}.
		</div>
		<nav
			aria-labelledby="footer_links"
			class="flex flex-wrap items-center justify-center gap-x-1 gap-y-1 sm:flex-nowrap sm:gap-x-0 sm:divide-x sm:divide-muted"
		>
			<p id="footer_links" class="sr-only">More on this site</p>
			{
				footerLinks.map((link) => (
					<a
						class="hover:text-global-text px-3 py-1 hover:underline sm:px-4 sm:py-0"
						href={link.path}
					>
						{link.title}
					</a>
				))
			}
		</nav>
	</div>
	<p class="mt-4 text-center text-xs font-normal">
		Built with
		<a class="hover:text-global-text underline" href="https://astro.build" rel="noreferrer" target="_blank">Astro</a>,
		forked from
		<a class="hover:text-global-text underline" href="https://github.com/chrismwilliams/astro-theme-cactus" rel="noreferrer" target="_blank">Cactus</a>.
		Source on
		<a class="hover:text-global-text underline" href="https://github.com/shdennlin/blog" rel="noreferrer" target="_blank">GitHub</a>.
	</p>
</footer>
