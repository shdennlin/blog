---
import type { CollectionEntry } from "astro:content";
import { buildMiniGraph, pathForMiniNode } from "@/lib/mini-graph";

interface Props {
	centerId: string;
	posts: CollectionEntry<"post">[];
}

const { centerId, posts } = Astro.props;
const { nodes, edges, total } = buildMiniGraph(centerId, posts);

const hasNeighbors = total > 1;
---

<div class="mb-6">
	<details open>
		<summary class="title hover:marker:text-accent cursor-pointer text-base">
			Local graph
		</summary>
		<div class="mt-3">
			{
				hasNeighbors ? (
					<>
						<svg
							viewBox="0 0 180 180"
							class="bg-special-lighter/40 h-auto w-full rounded"
							aria-label="Local connection graph"
						>
							<g stroke="currentColor" stroke-opacity="0.3">
								{edges.map((e) => (
									<line
										x1={e.x1}
										y1={e.y1}
										x2={e.x2}
										y2={e.y2}
										stroke-width={e.involvesCenter ? 1.5 : 0.6}
									/>
								))}
							</g>
							<g>
								{nodes.map((n) =>
									n.isCenter ? (
										<g>
											<circle
												cx={n.x}
												cy={n.y}
												r="6"
												class="fill-accent"
												stroke="var(--color-global-bg)"
												stroke-width="2"
											/>
											<text
												x={n.x}
												y={n.y + 16}
												text-anchor="middle"
												class="fill-global-text text-[8px]"
											>
												Current
											</text>
											<title>{n.title} (current)</title>
										</g>
									) : (
										<a href={pathForMiniNode(n)}>
											<circle
												cx={n.x}
												cy={n.y}
												r="4.5"
												class="fill-link hover:fill-accent transition-colors"
											/>
											<text
												x={n.x}
												y={n.y > 90 ? n.y + 13 : n.y - 8}
												text-anchor="middle"
												class="fill-global-text text-[7px]"
											>
												{n.title.length > 18 ? `${n.title.slice(0, 16)}...` : n.title}
											</text>
											<title>{n.title}</title>
										</a>
									),
								)}
							</g>
						</svg>
						<p class="text-muted mt-2 text-xs leading-relaxed">
							<span>{total - 1} linked {total - 1 === 1 ? "page" : "pages"}</span>
							<span class="mx-1">·</span>
							<a class="cactus-link" href="/graph/">full graph →</a>
						</p>
						<ul class="mt-2 space-y-1 text-xs" aria-label="Local graph pages">
							{
								nodes
									.filter((n) => !n.isCenter)
									.map((n) => (
										<li class="truncate">
											<a class="cactus-link" href={pathForMiniNode(n)}>
												{n.title}
											</a>
										</li>
									))
							}
						</ul>
					</>
				) : (
					<p class="text-muted text-xs">
						No local links yet · <a class="cactus-link" href="/graph/">full graph →</a>
					</p>
				)
			}
		</div>
	</details>
</div>
