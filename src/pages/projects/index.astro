---
import PostPreview from "@/components/blog/PostPreview.astro";
import { getProjects } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

const projects = (await getProjects()).sort(collectionDateSort);

const meta = {
	description: "Things I've built — side projects, tools, experiments.",
	title: "Projects",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-4">Projects</h1>
	<p class="text-muted mb-12 text-sm">Side projects, tools, experiments.</p>
	{projects.length === 0 && <p class="text-muted">Nothing public yet.</p>}
	<ul class="space-y-4" role="list">
		{
			projects.map((p) => (
				<li class="grid gap-1 sm:grid-cols-[auto_1fr] sm:[&_q]:col-start-2">
					<PostPreview post={p} withDesc withTags />
				</li>
			))
		}
	</ul>
</PageLayout>
