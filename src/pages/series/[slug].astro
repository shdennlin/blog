---
import type { GetStaticPaths } from "astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { groupBySeries, seriesSlug } from "@/lib/series";

export const getStaticPaths = (async () => {
	const posts = await getAllPosts();
	const groups = groupBySeries(posts);
	return [...groups.entries()].map(([name, list]) => ({
		params: { slug: seriesSlug(name) },
		props: { name, posts: list },
	}));
}) satisfies GetStaticPaths;

const { name, posts } = Astro.props;

const meta = {
	description: `All ${posts.length} parts of the “${name}” series.`,
	title: `Series · ${name}`,
};
---

<PageLayout meta={meta}>
	<p class="text-muted text-sm">Series</p>
	<h1 class="title mb-8">{name}</h1>
	<ol class="space-y-4">
		{
			posts.map((post, i) => (
				<li>
					<span class="text-muted me-2 inline-block w-6 text-end">{i + 1}.</span>
					<a class="cactus-link" href={`/posts/${post.id}/`}>
						{post.data.title}
					</a>
					{post.data.description && (
						<p class="text-muted ms-8 mt-1 text-sm">{post.data.description}</p>
					)}
				</li>
			))
		}
	</ol>
</PageLayout>
