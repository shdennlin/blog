---
import PostPreview from "@/components/blog/PostPreview.astro";
import { getNotes } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

const notes = (await getNotes()).sort(collectionDateSort);

const meta = {
	description: "Short-form notes — TILs, fragments, half-formed thoughts.",
	title: "Notes",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-4">Notes</h1>
	<p class="text-muted mb-12 text-sm">
		Short-form. Quick observations, things I've learned today, fragments. Less polished than posts.
	</p>
	{notes.length === 0 && <p class="text-muted">Nothing yet.</p>}
	<ul class="space-y-4" role="list">
		{
			notes.map((n) => (
				<li class="grid gap-1 sm:grid-cols-[auto_1fr] sm:[&_q]:col-start-2">
					<PostPreview post={n} withDesc withTags />
				</li>
			))
		}
	</ul>
</PageLayout>
