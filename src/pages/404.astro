---
import type { CollectionEntry } from "astro:content";
import PostPreview from "@/components/blog/PostPreview.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

const meta = {
	description: "The page you're looking for doesn't exist.",
	title: "404 — Not Found",
};

const recent = ((await getAllPosts()).sort(collectionDateSort) as CollectionEntry<"post">[]).slice(
	0,
	5,
);
---

<PageLayout meta={meta}>
	<h1 class="title mb-6">404 — page not found</h1>
	<p class="mb-12">
		That URL didn't match anything. Try the <a class="cactus-link" href="/posts/">posts list</a> or
		one of these recent ones:
	</p>
	<ul class="space-y-4" role="list">
		{
			recent.map((p) => (
				<li class="grid gap-1 sm:grid-cols-[auto_1fr]">
					<PostPreview post={p} />
				</li>
			))
		}
	</ul>
</PageLayout>
