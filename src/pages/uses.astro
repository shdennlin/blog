---
import { render } from "astro:content";
import FormattedDate from "@/components/FormattedDate.astro";
import { getStaticPage } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";

const page = await getStaticPage("uses");
const Rendered = page ? (await render(page)).Content : null;

const meta = {
	description: "Hardware, software, and tools I use day to day.",
	title: "Uses",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-4">Uses</h1>
	<p class="text-muted mb-8 text-sm">
		Hardware, software, and tools I use day-to-day.
		Inspired by <a class="cactus-link" href="https://uses.tech" rel="noreferrer" target="_blank">uses.tech</a>.
	</p>
	{
		Rendered && page ? (
			<>
				<div class="prose prose-sm max-w-none">
					<Rendered />
				</div>
				<p class="text-muted mt-12 text-xs">
					Last updated: <FormattedDate date={page.data.updatedDate ?? page.data.publishDate} />
				</p>
			</>
		) : (
			<p class="text-muted">
				Not written yet — add <code>vault/Blog/uses.md</code> with <code>type: page</code> and <code>publish: true</code>.
			</p>
		)
	}
</PageLayout>
