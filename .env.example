# Local dev environment template. Copy to .env (gitignored) and fill in
# only the variables for the features you want to test locally.
#
# Production values live in Cloudflare Pages → Settings → Environment.
# Every variable here is OPTIONAL — features render nothing when unset.
#
# See DEPLOY.md for what each one does and how to obtain it.

# Cloudflare Web Analytics (only loads in production builds)
# CF_BEACON_TOKEN=

# Giscus comments — set ALL FOUR or none
# GISCUS_REPO=shdennlin/blog
# GISCUS_REPO_ID=R_kgDO________
# GISCUS_CATEGORY=Comments
# GISCUS_CATEGORY_ID=DIC_kwDO________

# Webmentions (IndieWeb)
# WEBMENTION_URL=https://webmention.io/blog.shdennlin.com/webmention
# WEBMENTION_PINGBACK=https://webmention.io/blog.shdennlin.com/xmlrpc
# WEBMENTION_API_KEY=__server_only_secret__
